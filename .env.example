# Docker Compose ports exposed on the Windows host.
FRONTEND_PORT=3000
BACKEND_PORT=8000

# Browser-visible FastAPI URL, embedded into the frontend image at build time.
# Change the port here if BACKEND_PORT is changed.
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_MAX_FILE_SIZE_MB=15
NEXT_PUBLIC_UPLOAD_MODE=direct

# FastAPI runtime settings.
BIREFNET_MODEL_ID=ZhengPeng7/BiRefNet
MAX_UPLOAD_SIZE_MB=15
MAX_IMAGE_PIXELS=40000000
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# A practical ceiling for local CPU inference. Increase it if Docker Desktop
# reports an out-of-memory error.
BACKEND_MEMORY_LIMIT=6g

# Local object-storage mock. Do not place real S3 credentials in this file.
STORAGE_BACKEND=mock
PRESIGN_EXPIRES_SECONDS=900
