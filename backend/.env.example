# BIREFNET_MODEL_ID=ZhengPeng7/BiRefNet

# Object storage: use mock locally; set s3 only in a protected production environment.
STORAGE_BACKEND=mock
# STORAGE_MOCK_DIR=C:\path\to\FON\backend\.storage
# S3_ENDPOINT=https://storage.yandexcloud.net
# S3_BUCKET=fon-private-images
# S3_REGION=ru-central1
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
PRESIGN_EXPIRES_SECONDS=900
